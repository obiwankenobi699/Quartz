			"boundElements": [],
			"updated": 1772706859660,
			"locked": true,
			"text": "\n\npublic class NumbersExample {\n    public static void main(String[] args) {\n        // write a function that takes in a number and prints it\n        // print first 5 numbers: 1 2 3 4 5\n\n        print1(1);\n    }\n\n    static void print1(int n) {\n        System.out.println(n);\n        print2(2);\n    }\n\n    static void print2(int n) {\n        System.out.println(n);\n        print3(3);\n    }\n\n    static void print3(int n) {\n        System.out.println(n);\n        print4(4);\n    }\n\n    static void print4(int n) {\n        System.out.println(n);\n        print5(5);\n    }\n\n    // func body here changes\n    static void print5(int n) {\n        System.out.println(n);\n    }\n}",
			"rawText": "\n\npublic class NumbersExample {\n    public static void main(String[] args) {\n        // write a function that takes in a number and prints it\n        // print first 5 numbers: 1 2 3 4 5\n\n        print1(1);\n    }\n\n    static void print1(int n) {\n        System.out.println(n);\n        print2(2);\n    }\n\n    static void print2(int n) {\n        System.out.println(n);\n        print3(3);\n    }\n\n    static void print3(int n) {\n        System.out.println(n);\n        print4(4);\n    }\n\n    static void print4(int n) {\n        System.out.println(n);\n        print5(5);\n    }\n\n    // func body here changes\n    static void print5(int n) {\n        System.out.println(n);\n    }\n}",
			"fontSize": 12.40107142857143,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "\n\npublic class NumbersExample {\n    public static void main(String[] args) {\n        // write a function that takes in a number and prints it\n        // print first 5 numbers: 1 2 3 4 5\n\n        print1(1);\n    }\n\n    static void print1(int n) {\n        System.out.println(n);\n        print2(2);\n    }\n\n    static void print2(int n) {\n        System.out.println(n);\n        print3(3);\n    }\n\n    static void print3(int n) {\n        System.out.println(n);\n        print4(4);\n    }\n\n    static void print4(int n) {\n        System.out.println(n);\n        print5(5);\n    }\n\n    // func body here changes\n    static void print5(int n) {\n        System.out.println(n);\n    }\n}",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
