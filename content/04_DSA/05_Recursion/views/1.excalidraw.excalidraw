			"updated": 1772706859661,
			"locked": true,
			"text": "Note: why lower print not removed from stack\nbecause until the function get completely executed it\nremain in stack\nas all function are connected to each other so after\n1,2,3,4,5 they remove according to \nLIFO\n\n\nAnd it Again come to the function from where our\nfunction call started",
			"rawText": "Note: why lower print not removed from stack\nbecause until the function get completely executed it remain in stack\nas all function are connected to each other so after 1,2,3,4,5 they remove according to \nLIFO\n\n\nAnd it Again come to the function from where our function call started",
			"fontSize": 16,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Note: why lower print not removed from stack\nbecause until the function get completely executed it remain in stack\nas all function are connected to each other so after 1,2,3,4,5 they remove according to \nLIFO\n\n\nAnd it Again come to the function from where our function call started",
			"autoResize": false,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
