		},
		{
			"id": "TZXusdA8",
			"type": "text",
			"x": 161.1961010547509,
			"y": -289.47944309189427,
			"width": 451.3828125,
			"height": 240,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 0.5,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"groupIds": [],
