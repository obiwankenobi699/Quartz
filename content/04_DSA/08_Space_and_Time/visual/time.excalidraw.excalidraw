			"isDeleted": false,
			"boundElements": [],
			"updated": 1773773379444,
			"link": null,
			"locked": false,
			"text": "So in this equation after solving we\nget the time taken to execute the\ncode \nbut what we want is the function so\nwe dont consider the constants",
			"rawText": "So in this equation after solving we get the time taken to execute the code \nbut what we want is the function so we dont consider the constants",
			"fontSize": 16,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
